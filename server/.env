# Server Configuration
PORT=5000

# MongoDB Atlas Connection String
# আপনার ক্লাস্টার থেকে কপি করা কানেকশন স্ট্রিংটি এখানে দিন
# মনে রাখবেন <password> এর জায়গায় আপনার ডেটাবেস পাসওয়ার্ডটি বসিয়ে দিন
MONGO_URI=mongodb+srv://alfaravi17_db_user:2chc4KeYR2LS1GQP@cluster0.yhlxsgv.mongodb.net/?appName=Cluster0

# JWT Secret Key (এটি যেকোনো জটিল স্ট্রিং হতে পারে)
JWT_SECRET=your_super_secret_jwt_key_2026_faravi

# Supabase Storage Configuration
# আপনার Supabase প্রজেক্ট সেটিংস > API থেকে এইগুলো পাবেন
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_public_key

# Optional: যদি আপনি Node Environment সেট করতে চান
NODE_ENV=development